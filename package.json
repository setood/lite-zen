{
  "name": "lite-zen",
  "displayName": "Lite Zen",
  "description": "Toggle all side panels with a single hotkey, keeping only the editor visible",
  "version": "1.1.6",
  "publisher": "setood",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/setood/lite-zen"
  },
  "icon": "media/icon.png",
  "sponsor": {
    "url": "https://ko-fi.com/setood"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "contributes": {
    "commands": [
      {
        "command": "liteZen.toggle",
        "title": "Lite Zen: Toggle All Panels"
      },
      {
        "command": "liteZen.show",
        "title": "Lite Zen: Show All Panels"
      }
    ],
    "keybindings": [
      {
        "command": "liteZen.toggle",
        "key": "ctrl+k ctrl+\\",
        "mac": "cmd+k cmd+\\"
      },
      {
        "command": "liteZen.show",
        "key": "escape",
        "when": "liteZen.isHidden && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Lite Zen",
      "properties": {
        "liteZen.hideSidebar": {
          "type": "boolean",
          "default": true,
          "description": "Hide the primary sidebar"
        },
        "liteZen.hidePanel": {
          "type": "boolean",
          "default": true,
          "description": "Hide the bottom panel"
        },
        "liteZen.hideActivityBar": {
          "type": "boolean",
          "default": false,
          "description": "Hide the activity bar"
        },
        "liteZen.hideStatusBar": {
          "type": "boolean",
          "default": false,
          "description": "Hide the status bar"
        },
        "liteZen.hideAuxiliaryBar": {
          "type": "boolean",
          "default": true,
          "description": "Hide the secondary sidebar (auxiliary bar)"
        },
        "liteZen.restoreSidebar": {
          "type": "boolean",
          "default": true,
          "description": "Restore the sidebar when toggling back"
        },
        "liteZen.restorePanel": {
          "type": "boolean",
          "default": true,
          "description": "Restore the bottom panel when toggling back"
        },
        "liteZen.restoreAuxiliaryBar": {
          "type": "boolean",
          "default": true,
          "description": "Restore the auxiliary bar when toggling back"
        },
        "liteZen.panelDetectionMethod": {
          "type": "string",
          "enum": [
            "auto",
            "tempDocument"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Use visible-lines heuristic on the current editor. Falls back to restoring the panel when detection is unreliable (short/empty files).",
            "Same heuristic, but when it is unreliable, opens a temporary long document to measure reliably instead of guessing."
          ],
          "description": "Method used to detect whether the bottom panel was open before hiding"
        },
        "liteZen.enableLogging": {
          "type": "boolean",
          "default": false,
          "description": "Write diagnostic logs to log.txt in the workspace root"
        }
      }
    }
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  }
}